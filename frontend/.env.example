# ---------------------------------------------------------------------------
# Local dev against the Python backend (default).
# Copy to .env.local and adjust if the backend runs elsewhere.
# ---------------------------------------------------------------------------
VITE_WS_URL=ws://localhost:8000/ws/contacts
VITE_BRIEFING_WS_URL=ws://localhost:8000/ws/briefing

# ---------------------------------------------------------------------------
# Public demo mode (the Vercel build). Set this and the app runs WITHOUT any
# backend: contacts come from the in-browser mock source, and the briefing is
# fetched from the serverless function at /api/briefing.
#   On Vercel: set VITE_DEMO_MODE=1 in the project's Environment Variables.
#   Locally:   `VITE_DEMO_MODE=1 npx vercel dev` to run app + function together.
# ---------------------------------------------------------------------------
# VITE_DEMO_MODE=1
# VITE_BRIEFING_URL=/api/briefing   # override only if the function is elsewhere
